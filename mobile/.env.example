# card_scan/mobile/.env — source of truth for app + Cloud Run Supabase auth
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_real_anon_jwt

# Production scan API (Cloud Run HTTPS)
# gcloud run services describe card-scan-api --region=us-central1 --format='value(status.url)'
EXPO_PUBLIC_CARD_SCAN_API_URL=https://card-scan-api-827778437977.us-central1.run.app

# Local scan API (Mac LAN IP while `make dev` runs). ipconfig getifaddr en0
EXPO_PUBLIC_CARD_SCAN_API_URL_LOCAL=http://192.168.1.34:8080

# Which API to call from the app: local | production (default: local when LOCAL url is set)
EXPO_PUBLIC_CARD_SCAN_API_TARGET=local

# Physical device + local Supabase: use LAN IP, not localhost
# EXPO_PUBLIC_SUPABASE_URL=http://192.168.1.10:54321
