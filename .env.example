# App auth (/scan, /status) — disabled for local dev; required on Cloud Run
AUTH_MODE=disabled
# Supabase URL + anon key: set in mobile/.env (EXPO_PUBLIC_SUPABASE_*).
# make dev / make test / deploy load them via infra/gcp/load_mobile_supabase_env.sh
SCAN_API_KEY=

# API
API_BASE_URL=http://localhost:8080
SQLITE_PATH=data/jobs.sqlite
UPLOAD_DIR=data/uploads
USE_GCS=false
GCS_BUCKET=

# Local dev: run /process inline (no Cloud Tasks)
SYNC_PROCESS=true
SKIP_PADDLEOCR=false
SKIP_VISION=true

# Vision (Ollama)
VISION_URL=http://localhost:11434
VISION_MODEL=llama3.2-vision:11b

# GCP (production)
GCP_PROJECT=
TASKS_LOCATION=us-central1
TASKS_QUEUE=card-scan-queue
TASKS_SERVICE_ACCOUNT=
TASKS_PROCESSOR_SECRET=

# Admin purge cron
ADMIN_PURGE_SECRET=change-me-in-production
